{# @var trip \App\Entity\Trip #}
{% set driver = trip.driver %}
{% set fn = driver.firstName|default('') %}
{% set ln = driver.lastName|default('') %}
{% set initials = (fn|slice(0, 1) ~ ln|slice(0, 1))|upper %}
{% if not initials %}
    {% set initials = driver.userIdentifier|slice(0, 2)|upper %}
{% endif %}
<div class="card trip-card-premium h-100 border-0 shadow-sm card-hover-lift">
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
            <div>
                <h3 class="h6 fw-semibold mb-1 text-body">
                    <i class="bi bi-geo-alt text-primary me-1"></i>{{ trip.departure }}
                    <i class="bi bi-arrow-right mx-1 text-muted"></i>
                    {{ trip.destination }}
                </h3>
                <p class="small text-muted mb-0">
                    <i class="bi bi-calendar-event me-1"></i>{{ trip.departureDateTime|date('d/m/Y à H:i') }}
                </p>
            </div>
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">{{ trip.seatsAvailable }} place{{ trip.seatsAvailable > 1 ? 's' : '' }}</span>
        </div>
        <div class="d-flex align-items-center gap-2 mb-3 mt-auto">
            <span class="avatar-initials rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0">{{ initials }}</span>
            <div class="small">
                <span class="text-muted d-block">Conducteur</span>
                <span class="fw-medium">{{ driver.fullName ? driver.fullName : driver.userIdentifier }}</span>
            </div>
        </div>
        <div class="d-flex align-items-center justify-content-between gap-2">
            <span class="fw-semibold text-primary">
                {% if trip.pricePerSeat is not null and trip.pricePerSeat != '' %}
                    {{ trip.pricePerSeat|number_format(2, ',', ' ') }} TND
                {% else %}
                    Gratuit
                {% endif %}
            </span>
            <a href="{{ path('app_trip_show', { id: trip.id }) }}" class="btn btn-outline-primary btn-sm">Voir le trajet</a>
        </div>
    </div>
</div>
