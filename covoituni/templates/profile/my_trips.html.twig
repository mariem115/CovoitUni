{% extends 'base.html.twig' %}

{% block title %}Mes trajets — {{ parent() }}{% endblock %}

{% macro trip_driver_card(trip) %}
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                    <h2 class="h6 fw-semibold mb-0">{{ trip.departure }} → {{ trip.destination }}</h2>
                    {% if trip.isActive %}
                        <span class="badge bg-success-subtle text-success border">Actif</span>
                    {% else %}
                        <span class="badge bg-secondary-subtle text-secondary border">Retiré</span>
                    {% endif %}
                </div>
                <p class="small text-muted mb-2"><i class="fa-solid fa-calendar me-1"></i>{{ trip.departureDateTime|date('d/m/Y H:i') }}</p>
                <p class="small mb-2">{{ trip.seatsAvailable }} place(s) libre(s) · {{ trip.pricePerSeat ? trip.pricePerSeat|number_format(2, ',', ' ') ~ ' TND' : 'Gratuit' }}</p>
                <p class="small mb-3">
                    <span class="badge bg-primary-subtle text-primary border rounded-pill">
                        <i class="fa-solid fa-users me-1"></i>{{ trip.bookedPassengerSeats }} passager(s)
                    </span>
                </p>
                <div class="mt-auto d-flex flex-wrap gap-2">
                    <a href="{{ path('app_trip_show', { id: trip.id }) }}" class="btn btn-outline-primary btn-sm">Voir</a>
                    {% if is_granted('EDIT', trip) %}
                        <a href="{{ path('app_trip_passengers', { tripId: trip.id }) }}" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-users me-1"></i>Passagers</a>
                        <a href="{{ path('app_trip_edit', { id: trip.id }) }}" class="btn btn-outline-secondary btn-sm">Modifier</a>
                    {% endif %}
                    {% if is_granted('DELETE', trip) and trip.isActive %}
                        <form method="post" action="{{ path('app_trip_delete', { id: trip.id }) }}" class="d-inline" onsubmit="return confirm('Retirer ce trajet ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ trip.id) }}">
                            <button type="submit" class="btn btn-outline-danger btn-sm">Supprimer</button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endmacro %}

{% import _self as t %}

{% block body %}
<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <h1 class="h3 fw-bold mb-0">Mes trajets</h1>
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('app_profile_edit') }}" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-user-gear me-1"></i>Profil et véhicule</a>
            <a href="{{ path('app_trip_new') }}" class="btn btn-primary btn-sm"><i class="fa-solid fa-plus me-1"></i>Nouveau trajet</a>
        </div>
    </div>

    <h2 class="h5 fw-bold mb-3">Mes trajets à venir</h2>
    {% if upcomingTrips is empty %}
        <div class="card border-0 shadow-sm mb-5">
            <div class="card-body text-muted py-4 text-center">Aucun trajet à venir.</div>
        </div>
    {% else %}
        <div class="row g-4 mb-5">
            {% for trip in upcomingTrips %}
                {{ t.trip_driver_card(trip) }}
            {% endfor %}
        </div>
    {% endif %}

    <h2 class="h5 fw-bold mb-3">Mes trajets passés</h2>
    {% if pastTrips is empty %}
        <div class="card border-0 shadow-sm">
            <div class="card-body text-muted py-4 text-center">Aucun trajet passé.</div>
        </div>
    {% else %}
        <div class="row g-4">
            {% for trip in pastTrips %}
                {{ t.trip_driver_card(trip) }}
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
