<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}{{ app_name }}{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 128 128'%3E%3Crect width='128' height='128' fill='%234F46E5'%3E%3C/rect%3E%3C/svg%3E">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
            <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
            <link href="{{ asset('css/app.css') }}" rel="stylesheet">
        {% endblock %}
    </head>
    <body class="cu-page-fade bg-light">
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
            <div class="container">
                <a class="navbar-brand navbar-brand-covoit d-flex align-items-center gap-2" href="{{ path('app_home') }}">
                    <i class="bi bi-car-front-fill text-primary" aria-hidden="true"></i>
                    <span>CovoitUni <span class="brand-emoji" aria-hidden="true">&#128663;</span></span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Menu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav mx-lg-auto my-2 my-lg-0 gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link nav-link-covoit {{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}" href="{{ path('app_home') }}">Accueil</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-covoit" href="{{ path('app_trip_index') }}">Trajets</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-covoit" href="{{ path('app_home') }}#how-it-works">Comment ça marche</a>
                        </li>
                    </ul>
                    <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-2 ms-lg-2">
                        {% if app.user %}
                            <a href="{{ path('app_trip_new') }}" class="btn btn-primary btn-sm px-3">Proposer un trajet</a>
                            <div class="dropdown">
                                <button class="btn btn-light border d-flex align-items-center gap-2 dropdown-toggle py-1 ps-2 pe-3" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="avatar-initials rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0">
                                        {% set fn = app.user.firstName|default('') %}
                                        {% set ln = app.user.lastName|default('') %}
                                        {% set ini = (fn|slice(0, 1) ~ ln|slice(0, 1))|upper %}
                                        {{ ini ?: app.user.userIdentifier|slice(0, 2)|upper }}
                                    </span>
                                    <span class="d-none d-sm-inline text-truncate" style="max-width: 8rem;">{{ app.user.userIdentifier }}</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                    <li><a class="dropdown-item" href="{{ path('app_profile_my') }}"><i class="bi bi-person me-2"></i>Mon profil</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_profile_trips') }}"><i class="bi bi-geo-alt me-2"></i>Mes trajets</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_reservation_my') }}"><i class="bi bi-ticket-perforated me-2"></i>Mes réservations</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-2"></i>Déconnexion</a></li>
                                </ul>
                            </div>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="btn btn-outline-primary btn-sm">Connexion</a>
                            <a href="{{ path('app_register') }}" class="btn btn-primary btn-sm">Inscription</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>

        <div class="container mt-3">
            {% for label, messages in app.flashes(['success', 'danger', 'error', 'info', 'warning']) %}
                {% for message in messages %}
                    <div class="alert alert-{{ label in ['error', 'danger'] ? 'danger' : label }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        <main>
            {% block body %}{% endblock %}
        </main>

        <footer class="footer-covoit mt-5 py-5" style="background-color: #1e293b; color: #e2e8f0;">
            <div class="container">
                <div class="row g-4">
                    <div class="col-md-4">
                        <h6 class="fw-semibold mb-3">À propos</h6>
                        <p class="small mb-0">{{ app_name }} met en relation les étudiants pour partager les trajets vers les campus et événements, en toute confiance.</p>
                    </div>
                    <div class="col-md-4">
                        <h6 class="fw-semibold mb-3">Liens utiles</h6>
                        <ul class="list-unstyled small mb-0">
                            <li class="mb-2"><a href="{{ path('app_home') }}">Accueil</a></li>
                            <li class="mb-2"><a href="{{ path('app_trip_index') }}">Rechercher un trajet</a></li>
                            <li class="mb-2"><a href="{{ path('app_home') }}#how-it-works">Comment ça marche</a></li>
                        </ul>
                    </div>
                    <div class="col-md-4">
                        <h6 class="fw-semibold mb-3">Contact</h6>
                        <p class="small mb-2"><i class="bi bi-envelope me-2"></i>contact@covoituni.example</p>
                        <p class="small mb-0"><i class="bi bi-building me-2"></i>Université partenaire</p>
                    </div>
                </div>
                <hr class="footer-divider my-4">
                <p class="small text-center mb-0">&copy; {{ 'now'|date('Y') }} {{ app_name }}. Tous droits réservés.</p>
            </div>
        </footer>
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
        {% endblock %}
    </body>
</html>
