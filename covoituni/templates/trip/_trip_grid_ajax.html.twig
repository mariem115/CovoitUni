{% if pagination|length == 0 %}
    <div class="card border-0 shadow-sm text-center py-5 px-4 trip-empty-state">
        <i class="fa-solid fa-inbox display-3 text-muted d-block mb-3" aria-hidden="true"></i>
        <h2 class="h5 fw-semibold">Aucun trajet ne correspond à votre recherche</h2>
        <p class="text-muted mb-0">Essayez d’élargir les critères.</p>
    </div>
{% else %}
    <div class="row g-4 trip-grid-ajax">
        {% for trip in pagination %}
            <div class="col-12 col-md-6 col-lg-4">
                {% include 'components/trip_card.html.twig' with { trip: trip } only %}
            </div>
        {% endfor %}
    </div>
{% endif %}
