{% extends 'base.html.twig' %}

{% block title %}Trajets — {{ parent() }}{% endblock %}

{% block body %}
<div
    class="container py-4"
    data-controller="search"
    data-search-url-value="{{ path('app_trip_index') }}"
>
    <div class="mb-4">
        <h1 class="h3 fw-bold mb-3">Rechercher un trajet</h1>
        <form
            class="card border-0 shadow-sm trip-search-form"
            method="get"
            action="{{ path('app_trip_index') }}"
            data-search-target="form"
            id="trip-search-form"
        >
            <div class="card-body p-4">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small text-muted">Départ</label>
                        <input type="text" name="departure" class="form-control" value="{{ departure }}" placeholder="Ville de départ" autocomplete="off" data-search-field>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted">Destination</label>
                        <input type="text" name="destination" class="form-control" value="{{ destination }}" placeholder="Destination" autocomplete="off" data-search-field>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small text-muted">Date</label>
                        <input type="date" name="date" class="form-control" value="{{ date }}" data-search-field>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small text-muted">Places min.</label>
                        <input type="number" name="seats" class="form-control" value="{{ seats }}" min="1" max="8" data-search-field>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search me-1"></i>Rechercher</button>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <p class="small text-muted mb-2">Suggestions rapides :</p>
    <div class="d-flex flex-wrap gap-2 mb-4">
        <a href="{{ path('app_trip_index', { departure: 'Tunis', destination: 'Sousse', seats: seats }) }}" class="badge rounded-pill text-decoration-none bg-primary-subtle text-primary border">Tunis → Sousse</a>
        <a href="{{ path('app_trip_index', { departure: 'Sousse', destination: 'Tunis', seats: seats }) }}" class="badge rounded-pill text-decoration-none bg-primary-subtle text-primary border">Sousse → Tunis</a>
        <a href="{{ path('app_trip_index', { departure: 'Tunis', seats: seats }) }}" class="badge rounded-pill text-decoration-none bg-secondary-subtle text-secondary border">Au départ de Tunis</a>
        <a href="{{ path('app_trip_index', { destination: 'Sousse', seats: seats }) }}" class="badge rounded-pill text-decoration-none bg-secondary-subtle text-secondary border">Vers Sousse</a>
        <a href="{{ path('app_trip_index', { seats: seats }) }}" class="badge rounded-pill text-decoration-none bg-light text-dark border">Tous les trajets</a>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <p class="text-muted small mb-0" data-search-target="meta">
            {{ paginationTotal }} résultat{{ paginationTotal > 1 ? 's' : '' }}
        </p>
        <div class="d-flex align-items-center gap-2">
            <div class="spinner-border spinner-border-sm text-primary d-none" role="status" data-search-target="spinner" aria-hidden="true">
                <span class="visually-hidden">Chargement…</span>
            </div>
            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_trip_new') }}" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Proposer un trajet</a>
            {% endif %}
        </div>
    </div>

    <div data-search-target="results">
        {% include 'trip/_trip_search_fragment.html.twig' %}
    </div>
</div>
{% endblock %}
