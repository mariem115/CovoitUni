{% extends 'base.html.twig' %}

{% block title %}{{ trip.departure }} → {{ trip.destination }} — {{ parent() }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
{% endblock %}

{% block body %}
{% set driver = trip.driver %}
{% set fn = driver.firstName|default('') %}
{% set ln = driver.lastName|default('') %}
{% set initials = (fn|slice(0, 1) ~ ln|slice(0, 1))|upper %}
{% if not initials %}{% set initials = driver.userIdentifier|slice(0, 2)|upper %}{% endif %}
{% set avgRating = driver.averageRating %}

<div class="container py-4">
    {% if is_granted('ROLE_PASSAGER') %}
        <a href="{{ path('app_trip_index') }}" class="btn btn-link text-decoration-none ps-0 mb-3"><i class="fa-solid fa-arrow-left me-1"></i>Retour aux trajets</a>
    {% else %}
        <a href="{{ path('app_profile_trips') }}" class="btn btn-link text-decoration-none ps-0 mb-3"><i class="fa-solid fa-arrow-left me-1"></i>Retour à mes trajets</a>
    {% endif %}

    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="trip-route mb-2">
                <span class="trip-route__from">{{ trip.departure }}</span>
                <i class="fa-solid fa-arrow-right text-primary flex-shrink-0"></i>
                <span class="trip-route__to">{{ trip.destination }}</span>
            </h1>
            <p class="small text-muted mb-2"><i class="fa-solid fa-clock me-1"></i>{{ tripTimingLabel }}</p>
            <div class="d-flex flex-wrap gap-2">
                <span class="badge bg-primary-subtle text-primary border rounded-pill px-3 py-2">
                    <i class="fa-solid fa-calendar me-1"></i>{{ trip.departureDateTime|date('d/m/Y à H:i') }}
                </span>
                <span class="badge bg-secondary-subtle text-secondary border rounded-pill px-3 py-2">
                    <i class="fa-solid fa-users me-1"></i>{{ trip.seatsAvailable }} / {{ trip.seatsTotal }} places libres
                </span>
                {% if not trip.isActive %}
                    <span class="badge bg-warning text-dark rounded-pill px-3 py-2">Non publié</span>
                {% endif %}
            </div>
        </div>
            {% if is_granted('EDIT', trip) and is_granted('ROLE_CONDUCTEUR') %}
            <div class="d-flex flex-wrap gap-2">
                <a href="{{ path('app_trip_edit', { id: trip.id }) }}" class="btn btn-outline-primary btn-sm">Modifier</a>
                <a href="{{ path('app_trip_passengers', { tripId: trip.id }) }}" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-users me-1"></i>Passagers</a>
                <form method="post" action="{{ path('app_trip_delete', { id: trip.id }) }}" onsubmit="return confirm('Retirer ce trajet de la liste publique ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ trip.id) }}">
                    <button type="submit" class="btn btn-outline-danger btn-sm">Supprimer</button>
                </form>
            </div>
        {% endif %}
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h2 class="h6 text-uppercase text-muted fw-semibold mb-3">Parcours sur la carte</h2>
                    <div
                        id="trip-map"
                        class="leaflet-trip-map mb-0"
                        style="height:250px;border-radius:12px"
                        data-departure="{{ trip.departure|e('html_attr') }}"
                        data-destination="{{ trip.destination|e('html_attr') }}"
                    ></div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h2 class="h6 text-uppercase text-muted fw-semibold mb-3">Détails</h2>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Départ</dt>
                        <dd class="col-sm-8">{{ trip.departure }}</dd>
                        <dt class="col-sm-4 text-muted">Destination</dt>
                        <dd class="col-sm-8">{{ trip.destination }}</dd>
                        <dt class="col-sm-4 text-muted">Date et heure</dt>
                        <dd class="col-sm-8">{{ trip.departureDateTime|date('d/m/Y à H:i') }}</dd>
                        <dt class="col-sm-4 text-muted">Places</dt>
                        <dd class="col-sm-8">{{ trip.seatsAvailable }} disponible(s) sur {{ trip.seatsTotal }}</dd>
                        <dt class="col-sm-4 text-muted">Prix</dt>
                        <dd class="col-sm-8">
                            {% if trip.pricePerSeat is not null and trip.pricePerSeat != '' %}
                                <strong class="text-primary">{{ trip.pricePerSeat|number_format(2, ',', ' ') }} TND</strong> par place
                            {% else %}
                                <span class="badge bg-success-subtle text-success border">Gratuit</span>
                            {% endif %}
                        </dd>
                        {% if trip.description %}
                            <dt class="col-sm-4 text-muted">Infos</dt>
                            <dd class="col-sm-8 mb-0" style="white-space: pre-wrap;">{{ trip.description }}</dd>
                        {% endif %}
                    </dl>
                </div>
            </div>

            {% if is_granted('EDIT', trip) and is_granted('ROLE_CONDUCTEUR') %}
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4 d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div>
                            <h2 class="h6 text-uppercase text-muted fw-semibold mb-1">Réservations</h2>
                            <p class="small text-muted mb-0">Confirmez ou refusez les demandes depuis la page dédiée.</p>
                        </div>
                        <a href="{{ path('app_trip_passengers', { tripId: trip.id }) }}" class="btn btn-primary btn-sm">Gérer les passagers</a>
                    </div>
                </div>
            {% endif %}

            {% if similarTrips is not empty %}
                <h2 class="h5 fw-bold mb-3">Trajets similaires</h2>
                <div class="row g-3">
                    {% for t in similarTrips %}
                        <div class="col-md-6">
                            {% include 'components/trip_card.html.twig' with { trip: t } only %}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="col-lg-4">
            <div class="sticky-lg-top" style="top: 5rem;">
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body p-4">
                        <h2 class="h6 text-uppercase text-muted fw-semibold mb-3">Conducteur</h2>
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <span class="avatar-initials rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:3rem;height:3rem;font-size:1rem;">{{ initials }}</span>
                            <div>
                                <div class="fw-semibold">{{ driver.fullName ? driver.fullName : driver.userIdentifier }}</div>
                                <div class="small text-muted star-rating" aria-label="Note moyenne">
                                    {% for i in 1..5 %}
                                        <i class="{{ i <= avgRating ? 'fa-solid fa-star' : 'fa-regular fa-star' }}"></i>
                                    {% endfor %}
                                    <span class="ms-1">({{ avgRating|number_format(1, ',', ' ') }}/5)</span>
                                </div>
                            </div>
                        </div>
                        {% if app.user.id != driver.id %}
                            <a href="{{ path('app_conducteur_public_profile', { id: driver.id }) }}" class="btn btn-outline-secondary w-100 mb-2"><i class="fa-solid fa-star me-2"></i>Profil et avis</a>
                        {% endif %}
                        <a href="mailto:{{ driver.userIdentifier }}" class="btn btn-outline-primary w-100"><i class="fa-solid fa-envelope me-2"></i>Contacter</a>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h2 class="h6 text-uppercase text-muted fw-semibold mb-3">Réservation</h2>
                        {% if userReservation %}
                            {% set st = userReservation.status %}
                            <p class="small mb-2">Vous avez une réservation sur ce trajet.</p>
                            <p class="mb-0">
                                <span class="status-badge status-badge--{{ st == 'pending' ? 'pending' : (st == 'confirmed' ? 'confirmed' : 'cancelled') }}">{{ st }}</span>
                                · {{ userReservation.seatsBooked }} place(s)
                            </p>
                        {% elseif bookInfo.canBook and is_granted('ROLE_PASSAGER') %}
                            <form method="post" action="{{ path('app_reservation_book', { tripId: trip.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('book_trip_' ~ trip.id) }}">
                                <button type="submit" class="btn btn-primary w-100">Réserver (1 place)</button>
                            </form>
                            <p class="small text-muted mt-2 mb-0"><a href="{{ path('app_reservation_my') }}">Voir mes réservations</a></p>
                        {% else %}
                            {% set reason = bookInfo.reason %}
                            <p class="small text-muted mb-0">
                                {% if reason == 'is_driver' %}Vous êtes le conducteur de ce trajet.
                                {% elseif reason == 'not_passenger' %}La réservation est réservée aux comptes passager.
                                {% elseif reason == 'no_seats' %}Plus de places disponibles.
                                {% elseif reason == 'already_booked' %}Vous avez déjà une réservation pour ce trajet.
                                {% elseif reason == 'trip_past' %}Ce trajet n’est plus disponible (date passée ou trajet retiré).
                                {% else %}Réservation impossible pour ce trajet.{% endif %}
                            </p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            var el = document.getElementById('trip-map');
            if (!el || typeof L === 'undefined') return;

            var dep = el.dataset.departure || '';
            var dest = el.dataset.destination || '';
            if (!dep || !dest) return;

            var map = L.map(el, { scrollWheelZoom: false }).setView([34.0, 9.5], 6);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            function nominatim(q) {
                var url = 'https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + encodeURIComponent(q + ', Tunisia');
                return fetch(url, { headers: { 'Accept-Language': 'fr' } }).then(function (r) { return r.json(); });
            }

            Promise.all([nominatim(dep), nominatim(dest)]).then(function (results) {
                var a = results[0][0];
                var b = results[1][0];
                if (!a || !b) return;
                var latlngA = [parseFloat(a.lat), parseFloat(a.lon)];
                var latlngB = [parseFloat(b.lat), parseFloat(b.lon)];
                var mA = L.marker(latlngA).addTo(map).bindPopup(dep);
                var mB = L.marker(latlngB).addTo(map).bindPopup(dest);
                L.polyline([latlngA, latlngB], { color: '#4F46E5', weight: 4, opacity: 0.85 }).addTo(map);
                map.fitBounds(L.latLngBounds(latlngA, latlngB), { padding: [36, 36] });
            }).catch(function () {});
        })();
    </script>
{% endblock %}
