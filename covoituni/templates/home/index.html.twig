{% extends 'base.html.twig' %}

{% block title %}Accueil — {{ parent() }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .hero-covoit {
            background: linear-gradient(135deg, #4F46E5 0%, #06B6D4 100%);
            color: #fff;
            padding: 4rem 0 4.5rem;
        }
        .hero-covoit .form-control, .hero-covoit .form-control:focus {
            border: none;
            box-shadow: 0 1px 3px rgba(0,0,0,.08);
        }
        .stat-card {
            border: none;
            background: #fff;
        }
        .how-icon {
            width: 3.5rem;
            height: 3.5rem;
            border-radius: 0.75rem;
            background: linear-gradient(135deg, rgba(79, 70, 229, 0.12), rgba(6, 182, 212, 0.15));
            color: #4F46E5;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }
        .cta-banner {
            background: linear-gradient(135deg, #3730A3 0%, #0e7490 100%);
            color: #fff;
            border-radius: 1rem;
        }
    </style>
{% endblock %}

{% block body %}
<section class="hero-covoit">
    <div class="container">
        <div class="row justify-content-center text-center mb-4">
            <div class="col-lg-9">
                <h1 class="display-5 fw-bold mb-3">Voyagez malin entre étudiants</h1>
                <p class="lead opacity-90 mb-0">Partagez vos trajets vers le campus, économisez et rencontrez d’autres étudiants en toute simplicité.</p>
            </div>
        </div>
        <form class="row g-2 justify-content-center align-items-end" method="get" action="{{ path('app_trip_index') }}">
            <div class="col-12 col-md-3 col-lg-3">
                <label class="form-label small text-white-50 text-start d-block mb-1">Départ</label>
                <input type="text" name="departure" class="form-control form-control-lg" placeholder="Ville de départ" autocomplete="off">
            </div>
            <div class="col-12 col-md-3 col-lg-3">
                <label class="form-label small text-white-50 text-start d-block mb-1">Destination</label>
                <input type="text" name="destination" class="form-control form-control-lg" placeholder="Destination" autocomplete="off">
            </div>
            <div class="col-12 col-md-3 col-lg-2">
                <label class="form-label small text-white-50 text-start d-block mb-1">Date</label>
                <input type="date" name="date" class="form-control form-control-lg">
            </div>
            <div class="col-12 col-md-2 col-lg-2">
                <label class="form-label small text-white-50 text-start d-block mb-1">Places min.</label>
                <input type="number" name="seats" class="form-control form-control-lg" value="1" min="1" max="8" title="Places disponibles minimum">
            </div>
            <div class="col-12 col-md-auto">
                <button type="submit" class="btn btn-light btn-lg w-100 px-4 fw-semibold text-primary">
                    <i class="bi bi-search me-2"></i>Rechercher
                </button>
            </div>
        </form>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card stat-card shadow-sm card-hover-lift h-100 text-center p-4">
                    <div class="display-6 fw-bold text-primary">{{ totalUsers }}</div>
                    <p class="text-muted mb-0 mt-2">étudiants inscrits</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card stat-card shadow-sm card-hover-lift h-100 text-center p-4">
                    <div class="display-6 fw-bold text-primary">{{ totalTrips }}</div>
                    <p class="text-muted mb-0 mt-2">trajets publiés</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card stat-card shadow-sm card-hover-lift h-100 text-center p-4">
                    <div class="display-6 fw-bold text-primary">100%</div>
                    <p class="text-muted mb-0 mt-2">gratuit</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="pb-5">
    <div class="container">
        <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-4">
            <h2 class="h3 fw-bold mb-0">Trajets récents</h2>
            <a href="{{ path('app_trip_index') }}" class="btn btn-outline-primary btn-sm">Voir tous les trajets</a>
        </div>
        {% if recentTrips is empty %}
            <p class="text-muted">Aucun trajet pour le moment. Soyez le premier à en proposer un !</p>
        {% else %}
            <div class="row g-4">
                {% for trip in recentTrips %}
                    <div class="col-md-6 col-lg-4">
                        {% include 'components/trip_card.html.twig' with { trip: trip } only %}
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

<section id="how-it-works" class="py-5 bg-white border-top border-bottom">
    <div class="container">
        <h2 class="h3 fw-bold text-center mb-5">Comment ça marche</h2>
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="how-icon mb-3"><i class="bi bi-person-plus"></i></div>
                <h3 class="h6 fw-semibold">1. Inscrivez-vous</h3>
                <p class="text-muted small mb-0">Créez votre compte gratuitement avec votre e-mail universitaire ou personnel.</p>
            </div>
            <div class="col-md-4">
                <div class="how-icon mb-3"><i class="bi bi-search"></i></div>
                <h3 class="h6 fw-semibold">2. Cherchez ou proposez</h3>
                <p class="text-muted small mb-0">Trouvez un trajet qui vous convient ou publiez le vôtre en quelques clics.</p>
            </div>
            <div class="col-md-4">
                <div class="how-icon mb-3"><i class="bi bi-emoji-smile"></i></div>
                <h3 class="h6 fw-semibold">3. Voyagez !</h3>
                <p class="text-muted small mb-0">Échangez avec votre conducteur ou vos passagers et profitez du trajet.</p>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="cta-banner p-4 p-md-5 text-center">
            <h2 class="h4 fw-bold mb-3">Vous avez une voiture ?</h2>
            <p class="opacity-90 mb-4 mx-auto" style="max-width: 32rem;">Aidez d’autres étudiants à se déplacer et partagez les frais de route.</p>
            <a href="{{ path('app_trip_new') }}" class="btn btn-light btn-lg fw-semibold text-primary">Proposer un trajet</a>
        </div>
    </div>
</section>
{% endblock %}
