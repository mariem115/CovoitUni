{% extends 'base.html.twig' %}

{% block title %}Accueil — {{ parent() }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .hero-covoit.hero-gradient {
            background: linear-gradient(135deg, #4F46E5 0%, #06B6D4 100%);
            color: #fff;
            padding: 4.5rem 0 4rem;
        }
        .stat-card {
            border: none;
            background: #fff;
        }
        .how-icon {
            width: 3.5rem;
            height: 3.5rem;
            border-radius: 0.75rem;
            background: linear-gradient(135deg, rgba(79, 70, 229, 0.12), rgba(6, 182, 212, 0.15));
            color: #4F46E5;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }
        .cta-banner {
            background: linear-gradient(135deg, #3730A3 0%, #0e7490 100%);
            color: #fff;
            border-radius: 1rem;
        }
    </style>
{% endblock %}

{% block body %}
<section class="hero-covoit hero-gradient">
    <div class="container">
        <div class="row justify-content-center text-center mb-5">
            <div class="col-lg-9">
                <h1 class="display-5 fw-bold mb-3">Voyagez malin entre étudiants</h1>
                <p class="lead opacity-90 mb-4">Partagez vos trajets vers le campus, économisez et rencontrez d’autres étudiants en toute confiance.</p>
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <a href="{{ path('app_login') }}" class="btn btn-light btn-lg px-4 fw-semibold text-primary">Se connecter</a>
                    <a href="{{ path('app_register') }}" class="btn btn-outline-light btn-lg px-4 fw-semibold">Créer un compte</a>
                </div>
                <p class="small opacity-75 mt-4 mb-0">La recherche et les réservations sont réservées aux membres connectés.</p>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light text-dark">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card stat-card shadow-sm card-hover-lift h-100 text-center p-4">
                    <div class="display-6 fw-bold text-primary">{{ totalUsers }}</div>
                    <p class="text-muted mb-0 mt-2">étudiants inscrits</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card stat-card shadow-sm card-hover-lift h-100 text-center p-4">
                    <div class="display-6 fw-bold text-primary">{{ totalTrips }}</div>
                    <p class="text-muted mb-0 mt-2">trajets actifs</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card stat-card shadow-sm card-hover-lift h-100 text-center p-4">
                    <div class="display-6 fw-bold text-primary">100%</div>
                    <p class="text-muted mb-0 mt-2">gratuit pour les étudiants</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="how-it-works" class="py-5 bg-white text-dark border-top border-bottom">
    <div class="container">
        <h2 class="h3 fw-bold text-center mb-5">Comment ça marche</h2>
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="how-icon mb-3"><i class="fa-solid fa-user-plus"></i></div>
                <h3 class="h6 fw-semibold">1. Inscrivez-vous</h3>
                <p class="text-muted small mb-0">Créez votre compte puis connectez-vous en choisissant passager ou conducteur.</p>
            </div>
            <div class="col-md-4">
                <div class="how-icon mb-3"><i class="fa-solid fa-magnifying-glass"></i></div>
                <h3 class="h6 fw-semibold">2. Cherchez ou proposez</h3>
                <p class="text-muted small mb-0">Les passagers recherchent des trajets ; les conducteurs publient les leurs.</p>
            </div>
            <div class="col-md-4">
                <div class="how-icon mb-3"><i class="fa-regular fa-face-smile"></i></div>
                <h3 class="h6 fw-semibold">3. Voyagez !</h3>
                <p class="text-muted small mb-0">Confirmez les réservations, échangez et profitez du covoiturage.</p>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light text-dark">
    <div class="container">
        <div class="cta-banner p-4 p-md-5 text-center">
            <h2 class="h4 fw-bold mb-3">Prêt à rouler avec CovoitUni ?</h2>
            <p class="opacity-90 mb-4 mx-auto" style="max-width: 32rem;">Créez votre compte ou connectez-vous pour accéder à la recherche, aux trajets et aux réservations.</p>
            <div class="d-flex flex-wrap justify-content-center gap-3">
                <a href="{{ path('app_register') }}" class="btn btn-light btn-lg fw-semibold text-primary">S’inscrire</a>
                <a href="{{ path('app_login') }}" class="btn btn-outline-light btn-lg fw-semibold">Connexion</a>
            </div>
        </div>
    </div>
</section>
{% endblock %}
